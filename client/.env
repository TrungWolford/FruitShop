# Environment
VITE_ENVIRONMENT=development

# API Configuration
# Development (localhost) - Đang dùng để test
VITE_API_BASE_URL=http://localhost:8080
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws

# Production URLs (uncomment khi deploy)
# VITE_API_BASE_URL=https://your-backend-api.com
# VITE_API_URL=https://your-backend-api.com
# VITE_WS_URL=wss://your-backend-api.com/ws

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=djjfohr4t
# WARNING: API_KEY should be handled on backend for security
VITE_CLOUDINARY_API_KEY=181433978759536
VITE_CLOUDINARY_UPLOAD_PRESET=fruitshop-uploads

# App Info
VITE_APP_NAME=FruitShop
VITE_APP_VERSION=1.0.0
VITE_DEBUG_API_CALLS=true

# Security & Performance
VITE_ENABLE_HTTPS=true
VITE_ENABLE_COMPRESSION=true

